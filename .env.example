# KIE.ai API Key (required)
KIE_API_KEY=your_kie_api_key_here

# Your app's public URL (used for callbacks)
# In development, use a tunnel like ngrok: https://xxxx.ngrok.io
NEXT_PUBLIC_APP_URL=http://localhost:3000

# SQLite database path (defaults to ./data/app.db)
DATABASE_PATH=./data/app.db

# Cloudflare R2 credentials (required for image storage)
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=ai-images

# R2 Public URL (optional - custom domain or R2.dev public bucket URL)
# e.g., https://pub-xxx.r2.dev or https://images.yourdomain.com
R2_PUBLIC_URL=

# Authentication
ADMIN_PASSWORD=your_secure_password_here
AUTH_SECRET=your_random_auth_secret_here

