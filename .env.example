# KIE.ai API key — get yours at https://kie.ai/api-key
KIE_API_KEY=your_kie_api_key_here

# Public callback URL for realtime task completion webhooks from KIE.ai.
# Set this to https://your-domain.com/api/callback so KIE can POST results
# to /api/callback, which then pushes them to the browser via /api/sse.
# KIE_CALLBACK_URL=https://your-domain.com/api/callback

# ──────────────────────────────────────────────────────────────────────────────
# Image Upload — reference images must be reachable via a public URL so the
# KIE API can fetch them. Configure ONE of the two options below.
# ──────────────────────────────────────────────────────────────────────────────

# Option A: Local disk storage (default, for dev / self-hosted)
# Set APP_BASE_URL to the public root of this server so the KIE API can
# download uploaded images.  e.g. https://your-domain.com or use a tunnel
# like ngrok for local dev.
# APP_BASE_URL=https://your-domain.com

# Option B: Cloudflare R2  (takes priority when all five vars are set)
# R2_ACCOUNT_ID=your_account_id
# R2_ACCESS_KEY_ID=your_r2_access_key_id
# R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
# R2_BUCKET_NAME=your_bucket_name
# R2_PUBLIC_URL=https://pub-xxxx.r2.dev   # or your custom domain
